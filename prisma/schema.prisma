generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  DONOR
  VOLUNTEER
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum CampaignCategory {
  EDUCATION
  HOSTEL
  SPONSORSHIP
  EMERGENCY
  VOLUNTEER
  GENERAL
}

enum DonationStatus {
  INITIATED
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  MANUAL
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  CANCELLED
}

enum StudentStatus {
  APPLIED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ACTIVE_SUPPORT
  COMPLETED
  SUSPENDED
}

enum VolunteerStatus {
  APPLIED
  APPROVED
  ACTIVE
  INACTIVE
  REJECTED
}

enum EventStatus {
  DRAFT
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum NotificationType {
  DONATION
  CAMPAIGN
  STUDENT
  VOLUNTEER
  EVENT
  SYSTEM
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum ContactInquiryStatus {
  NEW
  IN_REVIEW
  RESPONDED
  CLOSED
  SPAM
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  DONATION_INITIATED
  DONATION_SUCCESS
  DONATION_FAILED
  PAYMENT_CAPTURED
  ROLE_CHANGED
  STATUS_CHANGED
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  role   UserRole   @default(DONOR)
  status UserStatus @default(PENDING_VERIFICATION)

  phone   String?
  city    String?
  state   String?
  country String  @default("India")

  donorProfileCompleted Boolean   @default(false)
  lastLoginAt           DateTime?

  accounts Account[]
  sessions Session[]

  donations        Donation[]
  createdCampaigns Campaign[]
  student          Student?
  volunteer        Volunteer?

  notifications Notification[]
  auditLogs     AuditLog[]     @relation("AuditActor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

    studentApplications StudentApplication[]

  @@index([role])
  @@index([status])
  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Campaign {
  id          String  @id @default(uuid())
  title       String
  slug        String  @unique
  description String
  story       String?

  category CampaignCategory
  status   CampaignStatus   @default(DRAFT)

  goalAmountPaise   Int
  raisedAmountPaise Int @default(0)

  coverImageUrl String?
  videoUrl      String?

  startDate DateTime?
  endDate   DateTime?

  isFeatured Boolean @default(false)

  donations Donation[]

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([status])
  @@index([isFeatured])
  @@index([endDate])
  @@map("campaigns")
}

model Donation {
  id String @id @default(uuid())

  amountPaise Int
  currency    String @default("INR")

  status DonationStatus @default(INITIATED)

  donorName  String
  donorEmail String
  donorPhone String?

  isAnonymous Boolean @default(false)
  message     String?

  userId     String?
  campaignId String

  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Restrict)

  paymentTransactions PaymentTransaction[]

  receiptNumber String? @unique
  receiptUrl    String?

  donatedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
  @@index([campaignId])
  @@index([userId])
  @@index([donorEmail])
  @@map("donations")
}

model PaymentTransaction {
  id String @id @default(uuid())

  provider PaymentProvider
  status   PaymentStatus   @default(CREATED)

  amountPaise Int
  currency    String @default("INR")

  providerOrderId   String?
  providerPaymentId String?
  providerSignature String?
  providerRefundId  String?

  metadata Json?

  donationId String?
  donation   Donation? @relation(fields: [donationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider])
  @@index([status])
  @@index([providerOrderId])
  @@index([providerPaymentId])
  @@index([donationId])
  @@map("payment_transactions")
}

model Student {
  id String @id @default(uuid())

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  fullName String
  email    String?
  phone    String?

  dateOfBirth DateTime?
  gender      String?

  collegeName String?
  course      String?
  branch      String?
  yearOfStudy String?

  familyIncomePaise Int?
  address           String?
  city              String?
  district          String?
  state             String?
  pincode           String?

  status StudentStatus @default(APPLIED)

  requestedSupport String?
  approvedSupport  String?

  documents Json?

  hostelRecords  HostelFacility[]
  successStories SuccessStory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([phone])
  @@map("students")
}
model StudentApplication {
  id                     String                   @id @default(uuid())
  applicationReference   String                   @unique

  userId                 String?
  user                   User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)

  fullName               String
  email                  String
  phone                  String
  dateOfBirth            DateTime?
  gender                 String?

  district               String
  taluk                  String?
  address                String?

  courseType             String
  courseName             String
  collegeName            String
  university             String?
  currentYear            String
  currentSemester        String?
  admissionNumber        String?
  usn                    String?

  entranceExam           String?
  entranceRank           String?
  previousPercentage     String?

  annualFeePaise         Int
  paidAmountPaise        Int                      @default(0)
  requestedAmountPaise   Int

  familyIncomePaise      Int?
  incomeCertificateNo    String?
  receivesSsp            Boolean                  @default(false)
  receivesVidyasiri      Boolean                  @default(false)
  receivesOtherSupport   Boolean                  @default(false)
  otherSupportDetails    String?

  aadhaarLast4           String?

  admissionProofUrl      String?
  feeStructureUrl        String?
  incomeCertificateUrl   String?
  marksCardUrl           String?

  needStatement          String
  consentAccepted        Boolean                  @default(false)

  status                 StudentApplicationStatus @default(SUBMITTED)
  adminNotes             String?
  reviewedAt             DateTime?

  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  @@index([email])
  @@index([phone])
  @@index([district])
  @@index([status])
  @@index([courseType])
  @@index([createdAt])
}

model Volunteer {
  id String @id @default(uuid())

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  fullName String
  email    String
  phone    String?

  city  String?
  state String?

  skills       String[]
  availability String?
  interests    String[]

  status VolunteerStatus @default(APPLIED)

  events EventVolunteer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@map("volunteers")
}

model HostelFacility {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  hostelName String
  address    String
  city       String
  state      String

  monthlyCostPaise Int?
  supportStartDate DateTime?
  supportEndDate   DateTime?

  isActive Boolean @default(true)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([isActive])
  @@map("hostel_facilities")
}

model ImpactStory {
  id String @id @default(uuid())

  title   String
  slug    String @unique
  content String

  imageUrl String?
  videoUrl String?

  metrics Json?

  isFeatured  Boolean @default(false)
  isPublished Boolean @default(false)

  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isFeatured])
  @@index([isPublished])
  @@map("impact_stories")
}

model SuccessStory {
  id String @id @default(uuid())

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  title   String
  slug    String @unique
  content String

  imageUrl String?
  quote    String?

  educationOutcome String?
  supportSummary   String?

  isPublished Boolean   @default(false)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([isPublished])
  @@map("success_stories")
}

model Event {
  id String @id @default(uuid())

  title       String
  slug        String @unique
  description String

  location String?
  city     String?
  state    String?

  startDate DateTime
  endDate   DateTime?

  status EventStatus @default(DRAFT)

  maxVolunteers Int?
  imageUrl      String?

  volunteers EventVolunteer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([startDate])
  @@map("events")
}

model EventVolunteer {
  id String @id @default(uuid())

  eventId     String
  volunteerId String

  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  volunteer Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  assignedRole String?
  attended     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, volunteerId])
  @@index([eventId])
  @@index([volunteerId])
  @@map("event_volunteers")
}

model NewsletterSubscriber {
  id String @id @default(uuid())

  email String  @unique
  name  String?

  isActive Boolean @default(true)

  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  source String?

  @@index([isActive])
  @@map("newsletter_subscribers")
}

model Notification {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type   NotificationType
  status NotificationStatus @default(UNREAD)

  title   String
  message String

  actionUrl String?

  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("notifications")
}

model ContactInquiry {
  id String @id @default(uuid())

  name    String
  email   String
  phone   String?
  subject String
  message String

  status ContactInquiryStatus @default(NEW)

  source   String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@map("contact_inquiries")
}

model AuditLog {
  id String @id @default(uuid())

  actorId String?
  actor   User?   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  action   AuditAction
  entity   String
  entityId String?

  oldValue Json?
  newValue Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
enum StudentApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  DOCUMENTS_PENDING
  VERIFIED
  APPROVED
  REJECTED
  FUNDED
  DISBURSED
}