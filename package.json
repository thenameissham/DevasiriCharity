{
  "name": "devasiri-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade donation, sponsorship, hostel support, volunteering, and impact transparency platform for Devasiri Charitable Trust.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "db:seed": "tsx prisma/seed.ts",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "quality": "npm run typecheck && npm run lint && npm run format:check",
    "prepare": "prisma generate"
  },
